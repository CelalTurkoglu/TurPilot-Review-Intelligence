# Copy this file to .env and fill real values locally.
# Never commit the real .env file to GitHub.

# OpenRouter is used by web_scraping/absa_analysis.py for optional ABSA labelling.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Streamlit app defaults.
STREAMLIT_SERVER_PORT=8501

# Selenium scraper setting. Keep false unless undetected-chromedriver is stable on your machine.
SELENIUM_USE_UNDETECTED_CHROME=false
